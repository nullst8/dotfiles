{
  "layer": "top",
  "position": "top",
  "spacing": 4,
  "margin-top": 0,
  "margin-bottom": 0,

  "modules-left": ["hyprland/workspaces"],

  "modules-center": ["clock"],

  "modules-right": [
    "pulseaudio",
    "cpu",
    "memory",
    "battery",
    "custom/notification",
    "tray"
  ],

  "tray": {
    "icon-size": 20,
    "spacing": 10
  },

  "clock": {
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "format": "{:%H:%M}",
    "interval": 60
  },

  "cpu": {
    "format": "{usage}% CPU",
    "tooltip": false,
    "interval": 10
  },

  "memory": {
    "format": "{}% RAM",
    "interval": 10
  },

  "battery": {
    "states": {
      "warning": 30,
      "critical": 20
    },
    "format": "{capacity}% {icon}",
    "format-charging": "{capacity}% ´çĞ",
    "format-plugged": "{capacity}% ´çĞ",
    "format-icons": ["´ëä", "´ëâ", "´ëé", "´ëü", "´ëÇ"]
  },

  "pulseaudio": {
    "format": "{volume}% {icon}",
    "format-bluetooth": "{volume}% {icon}´èö",
    "format-muted": "´ÇĞ",
    "format-icons": {
      "headphone": "´ÇÑ",
      "hands-free": "´ûÉ",
      "headset": "´ûÉ",
      "phone": "´éò",
      "portable": "´éò",
      "car": "´å╣",
      "default": ["´ÇĞ", "´Çğ", "´Ç¿"]
    },
    "on-click": "pavucontrol"
  },

  "custom/notification": {
    "exec": "swaync-client -c",
    "on-click": "swaync-client -t",
    "return-type": "number",
    "format": "´â│ {}",
    "interval": 30,
    "tooltip": false,
    "signal": 8
  }
}
